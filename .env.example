# Copy to .env (gitignored) and fill in. Prefer 1Password (mypw.py) for real
# values; code reads these via env vars at runtime, never hard-coded.
#
# my-stt-tts is LLM-provider-agnostic. Pick ONE provider below. Anthropic is the
# recommended default, but any OpenAI-compatible endpoint works (OpenAI, Ollama,
# vLLM, LM Studio, …), and `claude-cli` needs no API key at all.

# Brain backend: anthropic | openai | openai-compatible | ollama | claude-cli
LLM_PROVIDER=anthropic
# Model id for the chosen provider (e.g. claude-haiku-4-5, gpt-4o-mini, llama3.1).
# For claude-cli this is the `claude --model` value (e.g. haiku, sonnet, opus).
LLM_MODEL=claude-haiku-4-5
# Optional: model for the "deep" path (e.g. claude-opus-4-8, gpt-4o, …)
LLM_MODEL_DEEP=claude-opus-4-8
# Optional: override base URL for OpenAI-compatible / local servers
# LLM_BASE_URL=http://localhost:11434/v1

# API key for your chosen provider (only one is needed):
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# Local servers (Ollama / vLLM / LM Studio) usually need no key.
# 'claude-cli' uses your logged-in Claude Code CLI (no key) and keeps a session
# id across turns for multi-turn memory.

# Optional: STT model, Piper voice dir, spoken-output prompt, voice + cadence
# STT_MODEL=mlx-community/parakeet-tdt-0.6b-v3
# PIPER_DATA_DIR=voices
# SYSTEM_PROMPT_FILE=prompts/system_prompt.md   # edit this file to change how it talks
# TTS_VOICE_EN=en_US-amy-medium                 # or use `my-stt-tts --list-voices` / --voice
# TTS_LENGTH_SCALE=1.1                           # >1 = slower / calmer delivery

# --- Natural conversation (Phase 7): barge-in, smart turn, streaming STT ---
# Barge-in: off | headphones | always. Keeps the mic live during playback and
# aborts speech when the user interrupts. WITHOUT acoustic echo cancellation (AEC)
# the mic hears the speakers, so use 'headphones' for reliable interruption;
# 'always' relies on the energy gate and may self-trigger on open speakers.
# BARGE_IN=off
# BARGE_IN_ENERGY=0.02            # RMS floor (0..1) to ignore open-speaker bleed
# Acoustic echo cancellation (R2-1): remove the assistant's own TTS from the mic
# so barge-in works on OPEN speakers, not just headphones.
#   off | nlms (software FIR) | voiceprocessing (macOS hardware) | auto (HW else NLMS)
# 'auto'/'voiceprocessing' need the `aec` extra (PyObjC) for the hardware path.
# AEC_MODE=off
# AEC_NLMS_TAPS=256              # software filter length (FIR taps)
# AEC_NLMS_MU=0.3               # NLMS step size in (0, 2]; higher = faster, less stable
# False-interrupt suppression (pipecat MinWords): need this much speech AND/OR
# this many words before an interruption is honoured (backchannels stay ignored).
# INTERRUPT_MIN_SPEECH_MS=350
# INTERRUPT_MIN_WORDS=2
# Acoustic interruption prediction (R2-3): a 3rd, purely-acoustic barge-in guard
# that scores sustained voiced energy + spectral features for intent-to-take-the-
# floor, so a real interruption is honoured before two words transcribe while
# backchannels ("mhm") are still talked through. Composes with the guards above.
# INTERRUPT_PREDICT=true
# INTERRUPT_PREDICT_THRESHOLD=0.6   # score in [0,1] above which it fires
# INTERRUPT_PREDICT_MIN_MS=240     # sustained voiced time before it can fire
# End-of-turn detector: smart (Smart Turn v3 prosody model; the DEFAULT — auto-
# downloaded on first run, falls back to silence if model/runtime unavailable) |
# silence (fixed timer; explicit opt-out).
# TURN_ANALYZER=smart
# SMART_TURN_MODEL_PATH=models/smart-turn-v3.0.onnx
# SMART_TURN_MODEL_URL=https://huggingface.co/pipecat-ai/smart-turn-v3/resolve/main/smart-turn-v3.0.onnx
# SMART_TURN_AUTO_DOWNLOAD=true     # fetch the model on first run (like Piper voices)
# SMART_TURN_THRESHOLD=0.5
# Streaming STT: emit partial transcripts during the turn (lower perceived latency).
# Re-decode is BOUNDED to the last STT_WINDOW_S seconds (R2-2), so partial latency
# and CPU don't grow with the utterance length.
# STT_STREAMING=false
# STT_WINDOW_S=7.0
