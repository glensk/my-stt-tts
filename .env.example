# Copy to .env (gitignored) and fill in. Prefer 1Password (mypw.py) for real
# values; code reads these via env vars at runtime, never hard-coded.
#
# my-stt-tts is LLM-provider-agnostic. Pick ONE provider below. Anthropic is the
# recommended default, but any OpenAI-compatible endpoint works (OpenAI, Ollama,
# vLLM, LM Studio, …), and the CLI brains `claude-cli` / `codex-cli` need no API
# key at all (they use your logged-in Claude / OpenAI codex CLI). Tip: just run
# ./quickstart.sh — it auto-detects a key-free brain for you.

# Brain backend: anthropic | openai | openai-compatible | ollama | claude-cli | codex-cli
LLM_PROVIDER=anthropic
# Model id for the chosen provider (e.g. claude-haiku-4-5, gpt-4o-mini, llama3.1).
# For claude-cli this is the `claude --model` value (e.g. haiku, sonnet, opus).
# For codex-cli this is the `codex exec --model` value (e.g. gpt-5-codex).
LLM_MODEL=claude-haiku-4-5
# Optional: model for the "deep" path (e.g. claude-opus-4-8, gpt-4o, …)
LLM_MODEL_DEEP=claude-opus-4-8
# Optional: override base URL for OpenAI-compatible / local servers
# LLM_BASE_URL=http://localhost:11434/v1

# API key for your chosen provider (only one is needed):
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# Local servers (Ollama / vLLM / LM Studio) usually need no key.
# 'claude-cli' uses your logged-in Claude Code CLI (no key) and keeps a session
# id across turns for multi-turn memory.
# 'codex-cli' uses your logged-in OpenAI codex CLI (no key) via non-interactive
# `codex exec`, isolated (read-only sandbox, --skip-git-repo-check in a scratch
# dir, --ignore-user-config). Stateless per call (no resume session id). Override
# the base command if your codex build differs (default `codex exec`):
# CODEX_CLI_CMD=codex exec
# NOTE: the `codex exec` flags are taken from the documented OpenAI Codex CLI
# reference and were not verified against a live binary in this repo.

# Optional: STT model, Piper voice dir, spoken-output prompt, voice + cadence
# STT_MODEL=mlx-community/parakeet-tdt-0.6b-v3
# PIPER_DATA_DIR=voices
# SYSTEM_PROMPT_FILE=prompts/system_prompt.md   # edit this file to change how it talks
# TTS_VOICE_EN=en_US-amy-medium                 # or use `my-stt-tts --list-voices` / --voice
# TTS_LENGTH_SCALE=1.1                           # >1 = slower / calmer delivery

# --- Locale: location + measurement units ---
# Injected into the system prompt so the assistant is location- and units-aware
# (weather, distances, temperatures), and used as the default for the get_weather
# tool (Open-Meteo, no API key). The location also derives the timezone for the
# "Current local time: …" line injected into the prompt every turn (Lausanne ->
# Europe/Zurich), so the assistant can tell the time on ANY brain (incl. claude-cli,
# which has no tool access here). Flags: --location / --units.
# LOCATION=Lausanne, Switzerland
# UNITS=metric                                   # metric | imperial (°C/km·h vs °F/mph)

# --- Voice capture: VAD endpointing + audio debugging ---
# Silero-VAD speech probability above which a frame is "speech". Kept LOW so a
# quiet-but-present voice (a ~10% mic level) is still captured — a high threshold
# treats soft speech as silence and ends the turn with an empty transcript.
# VAD_THRESHOLD=0.3                              # 0..1; lower = more sensitive
# VAD_SILENCE_SECONDS=0.7                        # contiguous silence that ends a turn
# Heavy audio-pipeline tracing (the GUI "debugger"): logs every action + each
# capture's sample_rate/#samples/duration/rms/peak, VAD + endpoint decisions, the
# per-evaluation wake max-score, and the STT input length + transcript — to stderr
# AND the GUI EVENT LOG (bus 'debug' events). Defaults ON under --browser; set
# explicitly to force on/off.
# DEBUG_AUDIO=true
# --- Log streams: the GUI EVENT LOG and the terminal log are kept in sync ---
# The two log streams are designed to be supersets of each other:
#   * MSTT_EVENT_LOG names a JSON-Lines file the FULL in-app EVENT LOG (every bus
#     event: state / transcript / response / music / wake / debug / log …) is appended
#     to, one event per line + a wall-clock timestamp — for after-the-fact debugging
#     (quickstart.sh sets it to logs/events-<ts>.jsonl). Unset/empty -> no file written.
#   * The Python logging library (the app's own logging, plus library output like the
#     onnxruntime CUDAExecutionProvider warning, Hugging Face notes, httpx requests) is
#     bridged INTO the EVENT LOG at app startup, so the EVENT LOG also captures those.
#   * MSTT_EVENT_CONSOLE mirrors every bus event to STDERR as a concise one-liner
#     (e.g. `[event:state] listening`), so a stderr capture (quickstart.sh tees stderr
#     to logs/quickstart-<ts>.log) sees the same events the GUI EVENT LOG shows. It
#     DEFAULTS ON whenever MSTT_EVENT_LOG is set (so quickstart runs get it for free);
#     set 1/true/on to force on, 0/false/off to force off. Library/test use stays silent.
# The ONE intentional divergence: chatty third-party INFO (httpx per-request lines) is
# kept on stderr but NOT mirrored into the EVENT LOG, to keep it readable.
# MSTT_EVENT_LOG=logs/events.jsonl
# MSTT_EVENT_CONSOLE=1
# Startup audio preflight HARD STOP: before the GUI / wake loop / push-to-talk
# starts, a ~0.5 s real capture confirms a usable 16 kHz path and that the mic
# queue isn't persistently overflowing. If it can't (unresolvable rate, flooding
# queue, no device, denied permission) the app REFUSES to run with a clear, actionable
# error instead of recording nothing. Power-user escape hatch (also --skip-audio-preflight):
# SKIP_AUDIO_PREFLIGHT=true                      # bypass the broken-audio gate

# --- Wake word (always-listen; openWakeWord) ---
# The phrase that wakes the assistant. The model path auto-derives from the phrase
# (wakewords/<phrase>.onnx) unless WAKE_MODEL_PATH is set. Pre-shipped models live
# in wakewords/ (maziko, nexus, alexa, jarvis, …); train your own — see
# wakewords/WAKEWORD.md. The capture path feeds openWakeWord int16 PCM (it requires
# 16-bit-int samples — a float32 feed is silently truncated to zeros and the wake
# word NEVER fires, score pinned at ~0.001); the conversion happens at the model
# boundary in wake.py so the rest of the pipeline stays float32.
# WAKE_PHRASE=maziko
# WAKE_MODEL_PATH=wakewords/maziko.onnx          # auto-derived from WAKE_PHRASE if unset
# Wake sensitivity (0..1): score >= this fires the wake word. Lower = triggers more
# easily / more false-positives; higher = stricter (may miss a quiet "maziko").
# Default 0.4. Surfaced live in the GUI as VOICE › "Wake sensitivity". On detection
# a distinct chime plays and the GUI flashes a wake cue.
# WAKE_THRESHOLD=0.4
# Phase-diverse detection (the "fires offline, never live" recall fix). openWakeWord
# scores once per 1280-sample (80 ms) frame, locked to ONE phase relative to the
# spoken word; the score swings ~25x with where that boundary lands. In a live loop
# the frame grid is fixed by capture timing, so a single utterance gets one phase —
# an unlucky alignment scores ~0.03 and never fires though the SAME audio at a better
# offset scores ~0.7. Running K detectors offset by 1280/K samples (fire on the max)
# covers the phase space: measured to lift recall 2/8 -> 5/8 synthesized voices with
# NO extra false-positives and a 0.22 real-time factor at 8. Default 8; 1 disables it.
# WAKE_PHASES=8
# Software input gain applied to SERVER-captured mic audio (the GUI mic-check + wake
# test diagnostics) before scoring/saving, clip-protected to ±1.0 so a hot capture is
# never wrapped. A quiet built-in mic often peaks at ~10–20%; 2.0 lifts it to a usable
# level. Reported to the GUI as processing.gain. Must be > 0 and ≤ 10. Default 2.0.
# MIC_GAIN=2.0
# Wake-debug recorder: on Start Wake, dump the first WAKE_DEBUG_SECONDS of the EXACT
# 16 kHz frames fed to the wake model to a WAV, and log sample rate / #samples /
# duration / rms / peak (0-100% level) / max+mean wake score — so a never-firing wake
# word is diagnosable as a CAPTURE problem (wrong rate / silent / clipped) vs MODEL
# recall (good audio, low score) from one file. Defaults ON whenever DEBUG_AUDIO is
# on (so under --browser it just works); set explicitly to force on/off. The WAV path
# is logged prominently so you can attach it.
# WAKE_DEBUG_CAPTURE=true
# WAKE_DEBUG_PATH=~/.cache/my-stt-tts/wake-debug.wav
# WAKE_DEBUG_SECONDS=5.0

# --- Natural conversation (Phase 7): barge-in, smart turn, streaming STT ---
# Barge-in: off | headphones | always. Keeps the mic live during playback and
# aborts speech when the user interrupts. WITHOUT acoustic echo cancellation (AEC)
# the mic hears the speakers, so use 'headphones' for reliable interruption;
# 'always' relies on the energy gate and may self-trigger on open speakers.
# BARGE_IN=off
# BARGE_IN_ENERGY=0.02            # RMS floor (0..1) to ignore open-speaker bleed
# Acoustic echo cancellation (R2-1): remove the assistant's own TTS from the mic
# so barge-in works on OPEN speakers, not just headphones.
#   off | nlms (software FIR) | voiceprocessing (macOS hardware) | auto (HW else NLMS)
# 'auto'/'voiceprocessing' need the `aec` extra (PyObjC) for the hardware path.
# AEC_MODE=off
# AEC_NLMS_TAPS=256              # software filter length (FIR taps)
# AEC_NLMS_MU=0.3               # NLMS step size in (0, 2]; higher = faster, less stable
# Hardware-AEC capture (R3-4): when AEC_MODE=voiceprocessing/auto, capture mic audio
# THROUGH the macOS AVAudioEngine VoiceProcessingIO node so already-echo-cancelled PCM
# reaches Python (vs. sounddevice + in-Python NLMS). Falls back to sounddevice+NLMS if
# the PyObjC bridge is unavailable. Needs the `aec` extra.
# AEC_HW_CAPTURE=true
# Pre-VAD noise suppression (R3-6): clean mic frames AFTER echo cancellation and
# BEFORE VAD/STT to raise STT accuracy and cut false barge-ins in noisy rooms.
#   off | spectral (pure-numpy spectral gate, default-safe) | rnnoise (needs the
#   `denoiser` extra; falls back to spectral if the wheel is unavailable).
# DENOISER=off
# DENOISER_STRENGTH=1.0          # spectral over-subtraction factor (>=0)
# False-interrupt suppression (pipecat MinWords): need this much speech AND/OR
# this many words before an interruption is honoured (backchannels stay ignored).
# INTERRUPT_MIN_SPEECH_MS=350
# INTERRUPT_MIN_WORDS=2
# Acoustic interruption prediction (R2-3): a 3rd, purely-acoustic barge-in guard
# that scores sustained voiced energy + spectral features for intent-to-take-the-
# floor, so a real interruption is honoured before two words transcribe while
# backchannels ("mhm") are still talked through. Composes with the guards above.
# INTERRUPT_PREDICT=true
# INTERRUPT_PREDICT_THRESHOLD=0.6   # score in [0,1] above which it fires
# INTERRUPT_PREDICT_MIN_MS=240     # sustained voiced time before it can fire
# End-of-turn detector: smart (Smart Turn v3 prosody model; the DEFAULT — auto-
# downloaded on first run, falls back to silence if model/runtime unavailable) |
# silence (fixed timer; explicit opt-out).
# TURN_ANALYZER=smart
# SMART_TURN_MODEL_PATH=models/smart-turn-v3.0.onnx
# SMART_TURN_MODEL_URL=https://huggingface.co/pipecat-ai/smart-turn-v3/resolve/main/smart-turn-v3.0.onnx
# SMART_TURN_AUTO_DOWNLOAD=true     # fetch the model on first run (like Piper voices)
# SMART_TURN_THRESHOLD=0.5
# Streaming STT: emit partial transcripts during the turn (lower perceived latency).
# Re-decode is BOUNDED to the last STT_WINDOW_S seconds (R2-2), so partial latency
# and CPU don't grow with the utterance length.
# STT_STREAMING=false
# STT_WINDOW_S=7.0
# Streamed, low-latency TTS playout (R3-3): render + play the reply CLAUSE-by-clause
# so first audio plays within ~200-300 ms instead of after the whole sentence. Keeps
# barge-in cancel semantics. On by default; disable with TTS_STREAMING=false.
# TTS_STREAMING=true
# TTS_STREAM_MIN_CHARS=12        # min speakable chars before a sub-sentence clause fires
# TTS_STREAM_FRAME=1024          # OutputStream write block (samples) for streamed playout

# --- Network audio transport (R2-5): whole-house satellites + the browser ---
# Where the loop sources mic audio and sinks TTS audio:
#   local      (default) — the local sound card via sounddevice
#   websocket            — run a server that bridges remote clients into the pipeline
#   webrtc               — a real RTCPeerConnection (R3-1): Opus + jitter buffer + ICE
#                          NAT traversal; the browser uses getUserMedia + WebRTC. The
#                          WS PCM path stays as a fallback. Needs the 'webrtc' extra.
# `my-stt-tts --transport websocket` then serves ws://TRANSPORT_HOST:TRANSPORT_PORT.
# Connect a satellite with: python -m my_stt_tts.satellite ws://HOST:PORT [--token T]
# Needs the 'transport' extra: uv sync --extra transport (or --extra webrtc for WebRTC)
# Full-duplex barge-in (R3-2): when BARGE_IN is on, a satellite/browser user can
# interrupt the reply over the wire — the mic stays live during TTS and a confirmed
# interruption cancels the outbound TTS + the LLM stream (same as the local loop).
# TRANSPORT=local
# TRANSPORT_HOST=0.0.0.0          # bind LAN-wide so satellites can reach it
# TRANSPORT_PORT=8770
# TRANSPORT_TOKEN=                # optional shared secret the client must present

# --- In-conversation tool / function calling (R2-7) ---
# Let the model call tools mid-conversation (get_time, calculator, home_control ->
# routes to the agent / Home Assistant dispatch). Works with the anthropic + openai
# providers' native tool-use round-trip. The legacy "agent, ..." path still works.
# TOOLS_ENABLED=true

# --- Play music from YouTube ---
# A LOCAL intent router in the turn path resolves "play <song>" (EN/DE/FR) with
# yt-dlp and plays it through a stoppable background player BEFORE the LLM, so it
# works for EVERY brain (incl. the default claude-cli, which does no tool-calling).
# "stop" / "pause" / "resume" control the running track. yt-dlp is the `music`
# extra (uv-installable: `uv sync --extra music`); the PLAYER is a SYSTEM tool —
# install mpv (preferred, supports pause/resume: `brew install mpv`) or ffmpeg
# (gives ffplay; stop only). MUSIC_PLAYER=auto picks mpv -> ffplay -> yt-dlp
# download. API brains (anthropic/openai) can also call the play_music/stop_music
# tools, but the intent router is the primary, cross-brain path.
#
# Every play/stop/pause/resume (router OR GUI button) ALWAYS renders an assistant
# bubble in the transcript (a final bus.response, e.g. "▶ Playing: <title>.") and
# speaks it, AND publishes a structured GUI event
# {"type":"music","status":"playing|stopped|paused|resumed","title","video_id","url"}
# (video_id is the 11-char YouTube id, so the GUI can embed the video). Control
# phrases incl. trailing politeness ("stop the music please", DE "stopp … bitte",
# FR "arrête … s'il te plaît") are ALWAYS handled locally and NEVER reach the LLM;
# a stop/pause with nothing playing is answered by the router ("Nothing is playing
# right now."). A live "System state: music is currently playing: …" line is
# injected into the LLM prompt every turn so questions like "what's playing?" are
# answered from live state. GUI buttons drive playback via the music_stop /
# music_pause / music_resume server actions.
# MUSIC_ENABLED=true
# MUSIC_PLAYER=auto               # auto | mpv | ffplay | download
# MUSIC_VOLUME=                   # 0..100 (mpv only); unset = player default
# Where the GUI surfaces music. Audio ALWAYS plays SERVER-side via mpv regardless
# of this — the setting only tells the control-room page whether to ALSO show the
# (muted) YouTube video when the page is local to the server. "server" = audio-only
# controls; "hybrid" (default) = the page MAY also embed the muted video. The
# server does not detect "local"; it just exposes the choice and keeps emitting the
# YouTube video_id on the music event.
# MUSIC_PLAYBACK=hybrid           # server | hybrid

# --- Optional cloud STT/TTS backends (R2-7) — LOCAL-FIRST, opt-in ---
# Cloud is selected only when the backend is 'cloud' AND a key is set; otherwise it
# falls back to local (parakeet-mlx / Piper) gracefully. Both speak an OpenAI-
# compatible API (set *_BASE_URL for a gateway / local server). Never hard-codes keys.
# STT_BACKEND=local               # local | whispercpp | faster-whisper | cloud/openai | deepgram
# STT_CLOUD_MODEL=whisper-1
# STT_CLOUD_BASE_URL=             # defaults to the OpenAI endpoint
# STT_CLOUD_API_KEY=              # falls back to OPENAI_API_KEY when unset
# TTS_BACKEND=local               # local (Piper/say) | cloud/openai | elevenlabs | cartesia
# TTS_CLOUD_MODEL=gpt-4o-mini-tts
# TTS_CLOUD_VOICE=alloy
# TTS_CLOUD_BASE_URL=
# TTS_CLOUD_API_KEY=              # falls back to OPENAI_API_KEY when unset

# --- Real cloud backend adapters (G1) — key-gated, graceful local fallback ---
# Selected via STT_BACKEND/TTS_BACKEND above; without a key they fall back to local.
# DEEPGRAM_API_KEY=               # enables STT_BACKEND=deepgram
# DEEPGRAM_MODEL=nova-3
# DEEPGRAM_LANGUAGE=              # unset = Deepgram auto-detects
# ELEVENLABS_API_KEY=             # enables TTS_BACKEND=elevenlabs (strong DE voice)
# ELEVENLABS_MODEL=eleven_multilingual_v2
# ELEVENLABS_VOICE_ID=Rachel
# CARTESIA_API_KEY=               # enables TTS_BACKEND=cartesia (needs CARTESIA_VOICE_ID)
# CARTESIA_MODEL=sonic-2
# CARTESIA_VOICE_ID=              # required for Cartesia

# --- Per-speaker persistent memory (G7) — cross-session recall, multi-user ---
# A store path turns persistence on (.json = JSON backend, else SQLite). Keyed per
# enrolled speaker (speaker_id); guests share a bucket. Unset = in-memory only.
# MEMORY_STORE=memory.db          # or memory.json
# MEMORY_MAX_TURNS=40             # per-speaker turns assembled into the prompt

# --- Speaker ID (G7) — embed each utterance, key memory to the enrolled person ---
# Opt-in. Only active when ON *and* voices are enrolled under ENROLL_DIR *and* the
# `speaker` extra (speechbrain) is installed; otherwise the loop runs as guest at
# zero added latency. Enrollment = one <name>.npy centroid (or a <name>/ dir of
# *.npy embeddings) per person under ENROLL_DIR.
# SPEAKER_ID=false                # true to enable per-utterance speaker ID
# ENROLL_DIR=enroll               # dir of <name>.npy enrollment centroids
# SPEAKER_THRESHOLD=0.45          # min cosine score to accept a match (else guest)
# SPEAKER_MARGIN=0.06             # top-two gap below which a match is 'ambiguous'

# --- Cross-platform / off-Mac brain (G8) — Linux brain + Mac/ESP32 satellites ---
# PLATFORM=auto                   # auto | macos | linux
# PLAYBACK_BACKEND=auto           # auto | sounddevice | aplay (Linux) | afplay (macOS)
# WHISPERCPP_MODEL=large-v3-turbo # model id for whispercpp / faster-whisper STT
# FASTER_WHISPER_COMPUTE=int8     # int8 | int8_float16 | float16 | float32
# AEC_MODE=auto                   # ... | webrtc (Linux WebRTC-APM) — falls back to NLMS

# --- Speech-to-speech / realtime LLM (R3-5) — bypass the STT->LLM->TTS cascade ---
# brain=realtime streams mic audio to a realtime speech-to-speech endpoint (OpenAI
# Realtime over WebSocket) and plays the returned audio back, collapsing the
# cascade's per-turn latency. Key-gated: without REALTIME_API_KEY/OPENAI_API_KEY the
# loop falls back to the cascade (with a clear log line). CLI: --realtime.
# BRAIN_MODE=cascade              # cascade (default) | realtime
# REALTIME_MODEL=gpt-4o-realtime-preview
# REALTIME_URL=wss://api.openai.com/v1/realtime
# REALTIME_API_KEY=               # falls back to OPENAI_API_KEY when unset
# REALTIME_VOICE=alloy
# REALTIME_AUDIO_FORMAT=pcm16     # pcm16 (24 kHz) | g711_ulaw (8 kHz, telephony)

# --- Per-stage latency telemetry (R3-7) ---
# Record per-turn STT / LLM-first-token / TTS / first-audio latencies, keyed by a
# speech_id, to events.bus (a `metrics` event) and a structured JSON-lines log, with
# an optional OpenTelemetry span (lazy import, off by default). CLI: --telemetry.
# TELEMETRY=false
# TELEMETRY_LOG_FILE=             # JSON-lines path (one turn per line); empty = no file
# TELEMETRY_OTEL=false            # emit an OpenTelemetry span per turn (needs the 'otel' extra)

# --- Telephony reach (R3-9): answer a phone call via Twilio Media Streams ---
# Bridges Twilio's base64 μ-law 8 kHz media frames <-> our int16 PCM (8k<->16k
# resample) over a WebSocket, so the same pipeline can take a phone call. Point a
# Twilio <Stream url="wss://HOST:PORT/"> at it. Needs the 'transport' extra
# (websockets). CLI: --telephony.
# TELEPHONY=false
# TELEPHONY_HOST=0.0.0.0          # bind so Twilio can reach it
# TELEPHONY_PORT=8771

# --- Verified first-run bootstrap (R3-8) ---
# `my-stt-tts --preflight` fetches AND SHA-256-checksums the Smart-Turn model (pinned
# hash) plus the configured Piper voices ahead of time and reports what's ready. At
# runtime, when endpointing falls back to the silence timer an explicit warning is
# surfaced (log + a bus `endpoint_fallback` event) instead of silently degrading.
# SMART_TURN_SHA256=07a133aba31e2d0b523f17f8c2e4e65efe6d8f685efd12ca4fe21ebf4e798991  # "" disables the pin
