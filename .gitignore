#.vscode/*
#!.vscode/settings.json
.vscode/
__pycache__/

# macOS
.DS_Store

# Editors / IDEs
.idea/
*.swp
*.swo
*~
.direnv/

# Python caching & environments
*.py[cod]
.mypy_cache/
.pytest_cache/
.venv/
venv/
env/

# .python-version is committed (pins the uv interpreter); override the global ignore
!.python-version

# General Secrets & Logs — never commit values; allow templates explicitly
.env
.env.*
!.env.example
!.env.template
!.env_template
!.env.sample
*.log
# Per-run output: quickstart-*.log AND the EVENT LOG events-*.jsonl live here.
# Whole dir ignored so neither is ever swept into a commit (*.log alone missed .jsonl).
logs/
*.key
*.pem
*.p12
*.pfx
credentials
credentials.json
credentials.yaml
credentials.yml
secrets.yaml
secrets.yml
.netrc
.pgpass
.aws/credentials

Icon?

# AI assistant private files (public conventions live in AGENTS.md)
CLAUDE.md
CLAUDE.local.md
# transient: agent worktrees, local settings — never source
.claude/
# per-session churn, machine-local
.claude-code-sessions

# Mic / wake diagnostic recordings (debug/recordings/*.wav) — saved per run for
# the GUI's /recordings/ route + the play_recording action; never source.
debug/

# Voice enrollment profiles (private)
enroll/

# Downloaded Piper TTS voices (large; fetched via piper.download_voices)
voices/

# Trained wake-word models (generated; see wakewords/WAKEWORD.md). User-trained
# models stay ignored, but the small pre-shipped set IS committed so the repo ships
# selectable wake words out of the box (~200 KB each).
wakewords/*.onnx
wakewords/*.tflite
!wakewords/maziko.onnx
!wakewords/nexus.onnx
!wakewords/alexa.onnx
!wakewords/jarvis.onnx
!wakewords/computer.onnx
!wakewords/athena.onnx
!wakewords/nova.onnx
!wakewords/luna.onnx
!wakewords/sage.onnx
!wakewords/orion.onnx

# Smart Turn v3 ONNX (large; auto-downloaded + checksum-verified on first run)
models/
