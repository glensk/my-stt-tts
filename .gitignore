#.vscode/*
#!.vscode/settings.json
.vscode/
__pycache__/

# macOS
.DS_Store

# Editors / IDEs
.idea/
*.swp
*.swo
*~
.direnv/

# Python caching & environments
*.py[cod]
.mypy_cache/
.pytest_cache/
.venv/
venv/
env/

# .python-version is committed (pins the uv interpreter); override the global ignore
!.python-version

# General Secrets & Logs — never commit values; allow templates explicitly
.env
.env.*
!.env.example
!.env.template
!.env_template
!.env.sample
*.log
# Per-run output: quickstart-*.log AND the EVENT LOG events-*.jsonl live here.
# Whole dir ignored so neither is ever swept into a commit (*.log alone missed .jsonl).
logs/
*.key
*.pem
*.p12
*.pfx
credentials
credentials.json
credentials.yaml
credentials.yml
secrets.yaml
secrets.yml
.netrc
.pgpass
.aws/credentials

Icon?

# AI assistant private files (public conventions live in AGENTS.md)
CLAUDE.md
CLAUDE.local.md
# transient: agent worktrees, local settings — never source
.claude/
# per-session churn, machine-local
.claude-code-sessions

# Mic / wake diagnostics — saved per run for the GUI's /recordings/ route + the
# play_recording action; never source. Mic checks: debug/recordings/*.wav. Wake
# tests: kept as training data in per-word folders debug/recordings/wake/<word>/*.wav
# plus the data-driven reliability log debug/wake_stats.json. The whole tree is ignored.
debug/

# Voice enrollment profiles (private)
enroll/

# Downloaded Piper TTS voices (large; fetched via piper.download_voices)
voices/

# Trained wake-word models (generated; see wakewords/WAKEWORD.md). User-trained
# models stay ignored, but the small pre-shipped set IS committed so the repo ships
# selectable wake words out of the box. Two groups:
#   * self-trained (~200 KB each): maziko, nexus, computer, athena, nova, …
#   * official openWakeWord, extensively-trained (the RELIABLE green-tier choice;
#     fetch/refresh with scripts/fetch_official_wakewords.py): alexa, hey_jarvis,
#     hey_mycroft. The official alexa REPLACES the self-trained one (preferred).
wakewords/*.onnx
wakewords/*.tflite
!wakewords/maziko.onnx
!wakewords/nexus.onnx
!wakewords/alexa.onnx
!wakewords/jarvis.onnx
!wakewords/computer.onnx
!wakewords/athena.onnx
!wakewords/nova.onnx
!wakewords/luna.onnx
!wakewords/sage.onnx
!wakewords/orion.onnx
# Official openWakeWord models (extensively trained; green tier):
!wakewords/hey_jarvis.onnx
!wakewords/hey_mycroft.onnx

# Smart Turn v3 ONNX (large; auto-downloaded + checksum-verified on first run)
models/
