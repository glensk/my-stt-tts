// Copy this file to `secrets.h` and fill in your values.
//   cp src/secrets.h.example src/secrets.h
// `secrets.h` is git-ignored (see esp32/.gitignore). Never commit credentials.
//
// Alternatively, define any of these via build_flags in platformio.ini, e.g.:
//   build_flags = -DWIFI_SSID='"myssid"' -DWIFI_PASS='"pw"'
#pragma once

// --- WiFi -----------------------------------------------------------------
#ifndef WIFI_SSID
#define WIFI_SSID "your-wifi-ssid"
#endif
#ifndef WIFI_PASS
#define WIFI_PASS "your-wifi-password"
#endif

// --- my-stt-tts server (native WebSocket transport, PROTOCOL.md §2) -------
// The LAN IP/host running `my-stt-tts --transport websocket`.
#ifndef SERVER_HOST
#define SERVER_HOST "192.168.1.10"
#endif
// transport_port (config.py default 8770).
#ifndef SERVER_PORT
#define SERVER_PORT 8770
#endif
// WebSocket path. The native server accepts any path; "/" is canonical.
#ifndef SERVER_PATH
#define SERVER_PATH "/"
#endif
// Shared token: set iff the server was started with --transport-token.
// Leave as "" (empty) when the server has no token.
#ifndef SERVER_TOKEN
#define SERVER_TOKEN ""
#endif
